{
  "version": 8,
  "name": "Robotaxi Tracker OpenFreeMap Dark",
  "metadata": {
    "maptiler:copyright": "OpenFreeMap, OpenMapTiles, OpenStreetMap contributors"
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet",
      "attribution": "<a href=\"https://openfreemap.org/\" target=\"_blank\">OpenFreeMap</a> <a href=\"https://www.openmaptiles.org/\" target=\"_blank\">OpenMapTiles</a> Data from <a href=\"https://www.openstreetmap.org/copyright\" target=\"_blank\">OpenStreetMap</a>"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#05070a"
      }
    },
    {
      "id": "landcover-ice",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "ice"],
      "paint": {
        "fill-color": "#1b2635",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "wood"],
      "paint": {
        "fill-color": "#10231f",
        "fill-opacity": 0.65
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", ["get", "class"], "grass"],
      "paint": {
        "fill-color": "#14251e",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#10251f",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "residential",
          "#0b1118",
          "industrial",
          "#141018",
          "commercial",
          "#12121a",
          "hospital",
          "#1d1218",
          "school",
          "#151824",
          "cemetery",
          "#112018",
          "#090d13"
        ],
        "fill-opacity": 0.78
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["!=", ["get", "brunnel"], "tunnel"],
      "paint": {
        "fill-color": "#071b2f",
        "fill-opacity": 0.95
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#12385a",
        "line-opacity": 0.85,
        "line-width": ["interpolate", ["exponential", 1.3], ["zoom"], 8, 0.35, 14, 1.2, 20, 5]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#111827",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 13, 0.15, 16, 0.45]
      }
    },
    {
      "id": "tunnel",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "brunnel"], "tunnel"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#1f2937",
        "line-dasharray": [0.8, 1.2],
        "line-opacity": 0.55,
        "line-width": ["interpolate", ["exponential", 1.4], ["zoom"], 5, 0.25, 12, 1.5, 18, 9]
      }
    },
    {
      "id": "roads-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        ["!=", ["get", "brunnel"], "tunnel"],
        ["in", ["get", "class"], ["literal", ["minor", "service", "track", "path"]]]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#1c2430",
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 10, 0.25, 14, 0.65],
        "line-width": ["interpolate", ["exponential", 1.45], ["zoom"], 10, 0.15, 14, 0.8, 18, 4]
      }
    },
    {
      "id": "roads-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        ["!=", ["get", "brunnel"], "tunnel"],
        ["in", ["get", "class"], ["literal", ["primary", "secondary", "tertiary", "trunk"]]]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#2d3542",
        "line-opacity": 0.82,
        "line-width": ["interpolate", ["exponential", 1.45], ["zoom"], 5, 0.4, 10, 1.1, 16, 5.5, 20, 18]
      }
    },
    {
      "id": "roads-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        ["!=", ["get", "brunnel"], "tunnel"],
        ["in", ["get", "class"], ["literal", ["motorway"]]]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#3b4352",
        "line-opacity": 0.9,
        "line-width": ["interpolate", ["exponential", 1.45], ["zoom"], 5, 0.7, 10, 1.8, 16, 7.5, 20, 24]
      }
    },
    {
      "id": "rail",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", ["get", "class"], "rail"],
      "paint": {
        "line-color": "#334155",
        "line-dasharray": [1, 1],
        "line-opacity": 0.6,
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.35, 16, 1.3]
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": [">=", ["get", "admin_level"], 2],
      "paint": {
        "line-color": "#334155",
        "line-dasharray": [2, 2],
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 3, 0.35, 8, 0.6],
        "line-width": ["interpolate", ["linear"], ["zoom"], 2, 0.45, 8, 1.1]
      }
    },
    {
      "id": "road-labels",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 12,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 9, 16, 11],
        "text-letter-spacing": 0,
        "text-rotation-alignment": "map"
      },
      "paint": {
        "text-color": "#8fa1b7",
        "text-halo-color": "#05070a",
        "text-halo-width": 1.2,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 12, 0.25, 14, 0.75]
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          3,
          ["match", ["get", "class"], "country", 12, "state", 11, 10],
          9,
          ["match", ["get", "class"], "city", 13, "town", 11, 10],
          14,
          ["match", ["get", "class"], "city", 16, "town", 13, 11]
        ],
        "text-letter-spacing": 0
      },
      "paint": {
        "text-color": "#b8c7dc",
        "text-halo-color": "#05070a",
        "text-halo-width": 1.4,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 3, 0.55, 8, 0.9]
      }
    }
  ]
}
