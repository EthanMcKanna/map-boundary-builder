      "source-layer": "landuse",
      "paint": {
        "fill-color": "#e7e2d4",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": [
        "!=",
        [
          "get",
          "brunnel"
        ],
        "tunnel"
      ],
      "paint": {
        "fill-color": "#55747a",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#6f8b90",
        "line-opacity": 0.75,
        "line-width": [
          "interpolate",
          [
            "exponential",
            1.3
          ],
          [
            "zoom"
          ],
          8,
          0.35,
          14,
          1.2,
          20,
          5
        ]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#ded7c7",
        "fill-opacity": 0.58
      }
    },
    {
      "id": "tunnel",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "==",
        [
          "get",
          "brunnel"
        ],
        "tunnel"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d6d0c2",
        "line-dasharray": [
          0.8,
          1.2
        ],
        "line-opacity": 0.7,
        "line-width": [
          "interpolate",
          [
            "exponential",
            1.4
          ],
          [
            "zoom"
          ],
          5,
          0.25,
          12,
          1.5,
          18,
          9
        ]
      }
    },
    {
      "id": "roads-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": [
        "all",
        [
          "!=",
          [
            "get",
            "brunnel"
          ],
          "tunnel"
        ],
        [
          "in",
          [
            "get",
            "class"
          ],
          [
            "literal",
            [
              "minor",
              "service",
              "track",
              "path"
            ]
          ]
        ]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d6d0c2",
        "line-opacity": 0.7,
        "line-width": [
          "interpolate",
          [
            "exponential",
            1.45
          ],
          [
            "zoom"
          ],
          10,
          0.15,
          14,
          0.8,
          18,
          4
        ]
      }
    },
