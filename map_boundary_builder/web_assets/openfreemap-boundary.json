          "Noto Sans Regular"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          3,
          [
            "match",
            [
              "get",
              "class"
            ],
            "country",
            12,
            "state",
            11,
            10
          ],
          9,
          [
            "match",
            [
              "get",
              "class"
            ],
            "city",
            13,
            "town",
            11,
            10
          ],
          14,
          [
            "match",
            [
              "get",
              "class"
            ],
            "city",
            16,
            "town",
            13,
            11
          ]
        ],
        "text-letter-spacing": 0
      },
      "paint": {
        "text-color": "#17211d",
        "text-halo-color": "#f8f6ee",
        "text-halo-width": 1.25,
